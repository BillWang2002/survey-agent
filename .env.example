# =============================================================================
# SurveyAgent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- DeepSeek API (Required) ---
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.1

# --- LLM Settings ---
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# --- Browser Settings ---
# Set to "true" for headless mode (no visible browser window)
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=100
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080

# --- Agent Behavior ---
ACTION_DELAY=0.5
PAGE_LOAD_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
MAX_PAGES=50
MAX_ACTIONS_PER_PAGE=100
FEEDBACK_MAX_RETRIES=3

# --- Logging & Debugging ---
LOG_DIR=./logs
TRACE_DIR=./traces
# Set to "true" to enable full audit recording: per-page screenshots + LLM decision JSONs.
# Artifacts are auto-cleaned after a successful run (kept on failure for debugging).
# Default: false (only the main .log file is produced).
AGENT_RECORD=false
ENABLE_TRACE=false

# --- Human-in-the-Loop / CAPTCHA Handling ---
# Webhook URL for CAPTCHA notifications (e.g., Slack, DingTalk, WeChat Work)
HUMAN_INTERFACE_WEBHOOK=
# Max seconds to wait for human to resolve CAPTCHA (default: 300 = 5 min)
CAPTCHA_TIMEOUT_SECONDS=300
# How often (in seconds) to check if CAPTCHA has been resolved automatically
CAPTCHA_POLL_INTERVAL=2.0
